{
  "name": "@almothafar/angular-signature-pad",
  "version": "10.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng build angular-signature-pad --watch",
    "prestart:demo": "npm run generate-build-info",
    "start:demo": "ng serve demo",
    "build": "ng build",
    "build:prod": "rimraf dist && ng build angular-signature-pad --configuration production && npm run copyExtra",
    "generate-build-info": "node scripts/generate-build-info.mjs",
    "prebuild:docs": "npm run generate-build-info",
    "build:docs": "rimraf docs && ng build demo --configuration production",
    "pack": "cd dist/ && npm pack",
    "publish": "cd dist/ && npm publish --access=public",
    "test": "ng test",
    "lint": "ng lint",
    "copyExtra": "node -e \"require('fs').copyFileSync('README.md', './dist/README.md');require('fs').copyFileSync('CHANGELOG.md', './dist/CHANGELOG.md');\""
  },
  "dependencies": {
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/router": "^22.0.2",
    "rxjs": "^7.8.2",
    "signature_pad": "^5.1.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@types/node": "^26.0.0",
    "@vitest/browser-playwright": "^4.1.9",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.5.0",
    "ng-packagr": "^22.0.0",
    "playwright": "^1.61.0",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}